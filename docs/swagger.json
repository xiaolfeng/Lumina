                        }
                    },
                    "401": {
                        "description": "未授权",
                        "schema": {
                            "$ref": "#/definitions/common.BaseResponse"
                        }
                    },
                    "404": {
                        "description": "密钥不存在",
                        "schema": {
                            "$ref": "#/definitions/common.BaseResponse"
                        }
                    }
