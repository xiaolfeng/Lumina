# ============================================
# Application
# ============================================
XLF_DEBUG=true
XLF_HOST=0.0.0.0
XLF_PORT=8080
APP_NAME=Lumina
APP_VERSION=v0.1.0

# ============================================
# PostgreSQL
# ============================================
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=bamboo_user
DATABASE_PASS=bamboo_pass
DATABASE_NAME=lumina
DATABASE_PREFIX=lum_
DATABASE_TIMEZONE=Asia/Shanghai

# ============================================
# Redis
# ============================================
NOSQL_HOST=localhost
NOSQL_PORT=6379
NOSQL_PASS=
NOSQL_DATABASE=1
NOSQL_PREFIX=lum:
NOSQL_POOL_SIZE=100

# ============================================
# Snowflake (Optional)
# ============================================
SNOWFLAKE_DATACENTER_ID=1
SNOWFLAKE_NODE_ID=1

# ============================================
# Q&A Configuration
# ============================================
# QA_SESSION_TTL=172800                  # Session默认TTL（秒），默认48小时

# Q&A 文件缓存目录（image/file 回答的 base64 文件存储）
LUMINA_CACHE_DIR=.lumina/cache

# ============================================
# WebAuthn 生物特征登录
# ============================================
XLF_BIOMETRIC_RP_ID=localhost
XLF_BIOMETRIC_RP_NAME=Lumina
XLF_BIOMETRIC_ORIGIN=http://localhost:8080

# ============================================
# RepoWiki Configuration
# ============================================
REPOWIKI_STORAGE_PATH=./.lumina/repowiki
REPOWIKI_MAX_CONCURRENT=1              # 同时进行的分析任务数
REPOWIKI_HMAC_SECRET=

# RepoWiki 编排引擎超时/配额/重试控制
REPOWIKI_PIPELINE_TIMEOUT_MIN=60       # Pipeline 总超时（分钟）
REPOWIKI_OVERVIEW_TIMEOUT_MIN=10       # Coordinator 概要阶段超时（分钟）
REPOWIKI_EXPLORE_TIMEOUT_MIN=15         # Explore 每路超时（分钟）
REPOWIKI_ARCHITECT_TIMEOUT_MIN=10      # Architect 阶段超时（分钟）
REPOWIKI_WRITER_TIMEOUT_MIN=20         # Writer 每批超时（分钟）
REPOWIKI_VALIDATOR_TIMEOUT_MIN=5       # Validator 阶段超时（分钟）
REPOWIKI_EXPLORE_MAX_CONCURRENT=4      # Explore 最大并发数
REPOWIKI_WRITER_MAX_CONCURRENT=4       # Writer 最大并发数
REPOWIKI_WRITER_MAX_RETRY=2            # Writer 失败最大重试次数
REPOWIKI_MAX_TOKENS=2000000            # 每个 version 总 token 上限
REPOWIKI_MAX_REPO_SIZE_MB=2048         # 单仓库磁盘上限（MB）
REPOWIKI_MAX_VERSIONS=10               # 每个 config 保留版本数上限

# RepoWiki 异步任务配置
REPOWIKI_TASK_TIMEOUT=1800             # 任务超时判定阈值（秒，cron 用）
REPOWIKI_MAX_RETRY=3                   # 失败任务最大重试次数，默认 3

# ============================================
# LLM Configuration (Hot Config)
# ============================================
# LLM Provider/Model 配置已迁移到数据库，通过前端管理页面配置
# 此密钥用于加密 API Key，必填
LLM_ENCRYPT_SECRET=
