# ============================================
# Application
# ============================================
XLF_DEBUG=true
XLF_HOST=0.0.0.0
XLF_PORT=8080
APP_NAME=Lumina
APP_VERSION=v0.1.0

# ============================================
# PostgreSQL
# ============================================
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=bamboo_user
DATABASE_PASS=bamboo_pass
DATABASE_NAME=lumina
DATABASE_PREFIX=lum_
DATABASE_TIMEZONE=Asia/Shanghai

# ============================================
# Redis
# ============================================
NOSQL_HOST=localhost
NOSQL_PORT=6379
NOSQL_PASS=
NOSQL_DATABASE=1
NOSQL_PREFIX=lum:
NOSQL_POOL_SIZE=100

# ============================================
# Snowflake (Optional)
# ============================================
SNOWFLAKE_DATACENTER_ID=1
SNOWFLAKE_NODE_ID=1

# ============================================
# Q&A Configuration
# ============================================
# QA_SESSION_TTL=172800                  # Session默认TTL（秒），默认48小时

# Q&A 文件缓存目录（image/file 回答的 base64 文件存储）
LUMINA_CACHE_DIR=.lumina/cache
